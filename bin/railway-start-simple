#!/bin/bash

echo "=== Railway Startup ==="
export RAILS_ENV=production

# Create necessary directories
mkdir -p tmp/storage storage tmp/pids

# Run migrations (non-fatal — app can still serve the health check)
echo "Running migrations..."
bundle exec rails db:migrate 2>&1 || echo "Migration warning (may already be current)"

# Start Puma — do NOT gate on DB checks, let the health check pass
echo "Starting Puma on port ${PORT:-3000}"
exec bundle exec puma -C config/puma.rb
