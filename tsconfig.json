{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["DOM", "ES2020"],
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "allowJs": true,
    "outDir": "./dist",
    "sourceMap": true,
    "baseUrl": "./frontend",
    "paths": { "@/*": ["./*"] }
  },
  "include": ["frontend/**/*"],
  "exclude": ["node_modules"]
}
